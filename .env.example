# Supabase: use pooled URL for the app (Vercel), direct URL for migrations.
# Pooled (transaction mode, port 6543): DATABASE_URL
# Direct (port 5432): DIRECT_URL
#
# If your password contains @, [, ], #, or % — URL-encode it in the connection string.
# Example: P@ss[w0rd] → P%40ss%5Bw0rd%5D

DATABASE_URL="postgresql://postgres.[project-ref]:[URL_ENCODED_PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[URL_ENCODED_PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres"
