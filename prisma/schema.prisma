generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum EmploymentType {
  FULL_TIME
  CONTRACT
  PART_TIME
}

model Employee {
  id              String         @id @default(cuid())
  fullName        String
  jobTitle        String
  country         String
  salary          Int
  currency        String         @default("USD")
  department      String
  employmentType  EmploymentType @default(FULL_TIME)
  email           String         @unique
  hireDate        DateTime
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([country])
  @@index([country, jobTitle])
  @@index([salary])
  @@map("employees")
}
